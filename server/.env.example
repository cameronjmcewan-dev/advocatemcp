ANTHROPIC_API_KEY=sk-ant-api03-...
# Server-level API key — must match the API_KEY wrangler secret on the Worker
API_KEY=your-long-random-server-key
DATABASE_PATH=/app/data/dev.db
PORT=3000
API_BASE_URL=https://api.advocatemcp.com
MODEL=claude-sonnet-4-6

# Voyage embeddings (Phase 3 data layer — query semantic clustering)
VOYAGE_API_KEY=                          # required; absent = embeddings disabled silently
VOYAGE_MODEL=voyage-3.5-lite             # override only if voyage-3.5-lite not available in your region
EMBEDDINGS_DAILY_BUDGET_CENTS=50         # circuit breaker; real spend at 5k queries/day is <1c
EMBEDDINGS_BATCH_SIZE=96                 # outer backfill pass; voyage lite caps internal batch at 128
DISABLE_EMBEDDINGS=false                 # emergency kill switch; set to "true" to skip fire-and-forget

# Cluster job (Phase B)
CLUSTER_DISTANCE_THRESHOLD=0.3           # cosine distance; 0.3 ≈ 0.7 cosine sim
CLUSTER_LABEL_MODEL=claude-haiku-4-5     # model used for cluster labels
