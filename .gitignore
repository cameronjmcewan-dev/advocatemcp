# Environment files — all directories
.env
.env.local
.env.development
.env.production
.env.staging
**/.env
**/.env.local
**/.env.development
**/.env.production
**/.env.staging

# Vitest creates a .vite cache under node_modules/ at the CWD where it's run.
# Running vitest from the repo root (e.g. during one-off test invocations)
# leaves a root-level node_modules/.vite/ — keep it out of the repo.
node_modules/

server/node_modules/
server/dist/
server/*.db
server/*.db-shm
server/*.db-wal

# Worker build artifacts
.wrangler/
worker/.wrangler/
worker/dist/
worker/node_modules/

# Worktrees
.worktrees/

# pnpm artifacts — this repo is npm-native (committed package-lock.json + `npm ci`
# in CI). Ignore stray local pnpm files so a local `pnpm install` can never be
# committed or mislead. pnpm 11 renamed the build-script allowlist to `allowBuilds`
# (in pnpm-workspace.yaml), which is why the old package.json `pnpm.onlyBuiltDependencies`
# fix silently stopped working — see the npm-native pin in worker/ + server/ package.json.
pnpm-lock.yaml
pnpm-workspace.yaml

# Logs
*.log
.obsidian/
.obsidian/
.obsidian/
.gitnexus/

# Claude Code operator notes (Obsidian vault, not code)
claude-sessions/
.gstack/

