# Cloudflare Pages cache headers.
#
# Default Pages serves with `max-age=14400` (4 hours), which means a
# JS/CSS bug ships and customers don't see the fix for up to 4 hours.
# We hit this on Apr 27 with the dashboard logo bug.
#
# IMPORTANT: this file works on the Pages-managed domains
# (*.pages.dev) but Cloudflare's ZONE-LEVEL Page Rules and Cache
# Rules can override it for the custom domain (advocatemcp.com).
# If you change a value here and don't see it on advocatemcp.com:
#   1. Check the live header via `curl -I https://advocatemcp-site.pages.dev/<path>`
#      (Pages domain — _headers always wins here)
#   2. Compare with `curl -I https://advocatemcp.com/<path>`
#   3. If they differ, the zone has a Page Rule. Open Cloudflare
#      dashboard → advocatemcp.com → Rules → Page Rules / Cache Rules
#      and remove or relax the override.
#
# Patterns are most-specific first. Cloudflare Pages stops at the
# first match, so /assets/*.js doesn't fire if /assets/* fires above
# it. Avoid duplicate cache-control by using non-overlapping globs.

# JS / CSS / fonts under /assets, /js, /css → 5 min cache, must-revalidate.
# etag still serves 304 most of the time — bandwidth same, propagation fast.
/assets/*
  Cache-Control: public, max-age=300, must-revalidate

/js/*
  Cache-Control: public, max-age=300, must-revalidate

/css/*
  Cache-Control: public, max-age=300, must-revalidate

# HTML pages — always revalidate. Cheap CDN hit on every load.
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Long-cache the truly immutable: icons, OG image, favicons.
/icon-192.png
  Cache-Control: public, max-age=86400, immutable
/og-image.png
  Cache-Control: public, max-age=86400, immutable
/favicon.ico
  Cache-Control: public, max-age=86400, immutable

# Security headers (apply to everything).
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
